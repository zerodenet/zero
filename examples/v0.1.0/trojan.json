{
  "inbounds": [
    {
      "tag": "trojan-in",
      "listen": { "address": "0.0.0.0", "port": 443 },
      "protocol": {
        "type": "trojan",
        "password": "your-secret-password",
        "tls": {
          "cert_path": "certs/fullchain.pem",
          "key_path": "certs/privkey.pem"
        }
      }
    }
  ],
  "outbounds": [
    {
      "tag": "trojan-out",
      "protocol": {
        "type": "trojan",
        "server": "example.com",
        "port": 443,
        "password": "your-secret-password",
        "sni": "example.com",
        "insecure": false
      }
    },
    {
      "tag": "direct",
      "protocol": { "type": "direct" }
    }
  ],
  "mode": { "type": "rule" },
  "route": {
    "rules": [
      {
        "condition": { "type": "domain", "values": ["traffic-to-proxy.example.com"] },
        "action": { "type": "route", "outbound": "trojan-out" }
      }
    ],
    "final": { "type": "direct" }
  }
}
