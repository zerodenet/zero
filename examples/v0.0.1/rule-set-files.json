{
  "inbounds": [
    {
      "tag": "mixed-in",
      "listen": {
        "address": "127.0.0.1",
        "port": 7890
      },
      "protocol": {
        "type": "mixed"
      }
    }
  ],
  "outbounds": [
    {
      "tag": "direct",
      "protocol": {
        "type": "direct"
      }
    },
    {
      "tag": "block",
      "protocol": {
        "type": "block"
      }
    },
    {
      "tag": "node-a",
      "protocol": {
        "type": "socks5",
        "server": "127.0.0.1",
        "port": 2080
      }
    }
  ],
  "outbound_groups": [
    {
      "tag": "proxy",
      "type": "selector",
      "outbounds": ["node-a", "direct"],
      "selected": "node-a"
    }
  ],
  "mode": {
    "type": "rule"
  },
  "route": {
    "rule_sets": [
      {
        "tag": "ads",
        "type": "file",
        "path": "rules/ads.txt",
        "format": "domain_list"
      },
      {
        "tag": "lan",
        "type": "file",
        "path": "rules/lan.txt",
        "format": "cidr_list"
      }
    ],
    "rules": [
      {
        "condition": {
          "type": "rule_set",
          "tag": "ads"
        },
        "action": {
          "type": "reject"
        }
      },
      {
        "condition": {
          "type": "rule_set",
          "tag": "lan"
        },
        "action": {
          "type": "route",
          "outbound": "direct"
        }
      }
    ],
    "final": {
      "type": "route",
      "outbound": "proxy"
    }
  }
}
