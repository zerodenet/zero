{
  "inbounds": [
    {
      "tag": "mixed-in",
      "listen": {
        "address": "127.0.0.1",
        "port": 7890
      },
      "protocol": {
        "type": "mixed"
      }
    }
  ],
  "outbounds": [
    {
      "tag": "direct",
      "protocol": {
        "type": "direct"
      }
    },
    {
      "tag": "block",
      "protocol": {
        "type": "block"
      }
    }
  ],
  "route": {
    "rules": [
      {
        "condition": {
          "type": "domain",
          "values": [
            "blocked.example",
            ".ads.local"
          ]
        },
        "action": {
          "type": "reject"
        }
      },
      {
        "condition": {
          "type": "ip",
          "values": [
            "10.0.0.0/8",
            "192.168.0.0/16"
          ]
        },
        "action": {
          "type": "route",
          "outbound": "direct"
        }
      }
    ],
    "final": {
      "type": "route",
      "outbound": "direct"
    }
  }
}
